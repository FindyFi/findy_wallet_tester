{
    "application": {
        "package": "com.gataca.identity",
        "activity": ".MainActivity",
        "email": "your.gataca.test@example.com",
        "pin": "123456"
    },
    "timeouts": {
        "default": 10,
        "pin_digit_delay": 0.3,
        "credential_offer": 30
    },
    "reporting": {
        "screenshot_on_failure": true
    },
    "onboarding": {
        "skip_if_done": true
    },
    "test_cases": {
        "procivis_pension": {
            "base_url": "https://issuer.procivis.pensiondemo.findy.fi",
            "credentials": {
                "credential_issuance": { "type": "issuance", "path": "pensioncredential.json" }
            }
        },
        "procivis_verifier": {
            "base_url": "https://verifier.procivis.pensiondemo.findy.fi",
            "credentials": {
                "pension_verification": { "type": "verification", "path": "/" }
            }
        }
    }
}
